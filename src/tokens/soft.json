{
  "$description": "WIP",

  "ink": { "$type": "color", "$value": "oklch(0.55 0.13 255)" },
  "paper": { "$type": "color", "$value": "oklch(0.99 0.004 250)" },

  "accent-1": { "$type": "color", "$value": "oklch(0.5 0.08 255)" },
  "accent-2": { "$type": "color", "$value": "oklch(0.62 0.11 255)" },
  "accent-3": { "$type": "color", "$value": "oklch(0.66 0.09 200)" },

  "positive": { "$type": "color", "$value": "oklch(0.62 0.17 150)" },
  "negative": { "$type": "color", "$value": "oklch(0.58 0.21 25)" },
  "warning": { "$type": "color", "$value": "oklch(0.75 0.16 75)" },
  "neutral": { "$type": "color", "$value": "oklch(0.62 0.02 255)" },

  "border-w-base": { "$type": "dimension", "$value": "1px" },
  "border-style": { "$type": "other", "$value": "solid" },

  "shadow": { "$type": "other", "$value": "0 4px 12px oklch(0.5 0.05 255 / 0.18)" },
  "shadow-hover": { "$type": "other", "$value": "0 10px 24px oklch(0.5 0.05 255 / 0.22)" },
  "shadow-active": { "$type": "other", "$value": "0 2px 6px oklch(0.5 0.05 255 / 0.16)" },

  "hover-shift-x": { "$type": "dimension", "$value": "0px" },
  "hover-shift-y": { "$type": "dimension", "$value": "0px" },

  "radius": { "$type": "dimension", "$value": "0.75rem" },

  "transition": { "$type": "other", "$value": "220ms cubic-bezier(0.2, 0, 0, 1)" },

  "font-display": { "$type": "fontFamily", "$value": "\"Inter\", system-ui, -apple-system, sans-serif" },
  "font-body": { "$type": "fontFamily", "$value": "\"Inter\", system-ui, -apple-system, sans-serif" },

  "space-1-base": { "$type": "dimension", "$value": "0.25rem" },
  "space-2-base": { "$type": "dimension", "$value": "0.5rem" },
  "space-3-base": { "$type": "dimension", "$value": "0.75rem" },
  "space-4-base": { "$type": "dimension", "$value": "1rem" },
  "space-5-base": { "$type": "dimension", "$value": "1.5rem" },
  "space-6-base": { "$type": "dimension", "$value": "2rem" }
}

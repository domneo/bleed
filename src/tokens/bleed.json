{
  "$description": "Bleed — the default theme. Semi-monotone blue/white/black scheme featuring brutalist fonts and hard edges.",

  "ink": { "$type": "color", "$value": "oklch(0.45 0.31 264)" },
  "paper": { "$type": "color", "$value": "oklch(0.97 0.005 280)" },
  "accent": { "$type": "color", "$value": "oklch(0.77 0.24 325.04)" },
  "positive-subtle": { "$type": "color", "$value": "oklch(from var(--positive) calc(l + 0.2) c calc(h + 50))" },
  "positive": { "$type": "color", "$value": "oklch(0.91 0.12 179.2)" },
  "positive-strong": { "$type": "color", "$value": "oklch(from var(--positive) calc(l - 0.4) c calc(h + 22))" },
  "negative-subtle": { "$type": "color", "$value": "oklch(from var(--negative) calc(l + 0.2) calc(c - 0.05) h)" },
  "negative": { "$type": "color", "$value": "oklch(0.8 0.18 -7.3)" },
  "negative-strong": { "$type": "color", "$value": "oklch(from var(--negative) calc(l - 0.25) c h)" },
  "warning-subtle": { "$type": "color", "$value": "oklch(from var(--warning) calc(l + 0.2) c h)" },
  "warning": { "$type": "color", "$value": "oklch(0.93 0.12 93.18)" },
  "warning-strong": { "$type": "color", "$value": "oklch(from var(--warning) calc(l - 0.4) calc(c + 0.05) h)" },
  "neutral-subtle": { "$type": "color", "$value": "oklch(from var(--neutral) calc(l + 0.175) calc(c + 0.1) calc(h + 4))" },
  "neutral": { "$type": "color", "$value": "color-mix(in oklch, var(--ink) 35%, var(--paper))" },
  "neutral-strong": { "$type": "color", "$value": "oklch(from var(--neutral) calc(l - 0.25) c h)" },

  "border-w": { "$type": "dimension", "$value": "2px" },
  "border-style": { "$type": "other", "$value": "dashed" },

  "shadow": { "$type": "other", "$value": "4px 4px 0 {ink}" },
  "shadow-hover": { "$type": "other", "$value": "2px 2px 0 {ink}" },
  "shadow-active": { "$type": "other", "$value": "0 0 0 {ink}" },

  "hover-shift-x": { "$type": "dimension", "$value": "2px" },
  "hover-shift-y": { "$type": "dimension", "$value": "2px" },

  "radius": { "$type": "dimension", "$value": "0px" },

  "transition": { "$type": "other", "$value": "120ms cubic-bezier(0.2, 0, 0, 1)" },

  "font-display": { "$type": "fontFamily", "$value": "\"BBH Bartle\", \"Arial Black\", system-ui, sans-serif" },
  "font-body": { "$type": "fontFamily", "$value": "\"DM Mono\", ui-monospace, \"SF Mono\", Menlo, monospace" },

  "font-size-1": { "$type": "dimension", "$value": "clamp(0.875rem, 0.833rem + 0.208vw, 1rem)" },
  "font-size-2": { "$type": "dimension", "$value": "clamp(1rem, 0.958rem + 0.208vw, 1.125rem)" },
  "font-size-3": { "$type": "dimension", "$value": "clamp(1.125rem, 1.042rem + 0.417vw, 1.375rem)" },
  "font-size-4": { "$type": "dimension", "$value": "clamp(1.375rem, 1.25rem + 0.625vw, 1.75rem)" },
  "font-size-5": { "$type": "dimension", "$value": "clamp(1.75rem, 1.583rem + 0.833vw, 2.25rem)" },
  "font-size-6": { "$type": "dimension", "$value": "clamp(2.25rem, 2rem + 1.25vw, 3rem)" },
  "font-size-7": { "$type": "dimension", "$value": "clamp(3rem, 2.667rem + 1.667vw, 4rem)" },

  "line-height-tight": { "$type": "other", "$value": "1.05" },
  "line-height-snug": { "$type": "other", "$value": "1.25" },
  "line-height-normal": { "$type": "other", "$value": "1.5" },

  "letter-spacing-tight": { "$type": "dimension", "$value": "-0.01em" },
  "letter-spacing-normal": { "$type": "dimension", "$value": "0em" },
  "letter-spacing-wide": { "$type": "dimension", "$value": "0.05em" },
  "letter-spacing-wider": { "$type": "dimension", "$value": "0.12em" },

  "space-1": { "$type": "dimension", "$value": "0.25rem" },
  "space-2": { "$type": "dimension", "$value": "0.5rem" },
  "space-3": { "$type": "dimension", "$value": "0.75rem" },
  "space-4": { "$type": "dimension", "$value": "1rem" },
  "space-5": { "$type": "dimension", "$value": "1.5rem" },
  "space-6": { "$type": "dimension", "$value": "2rem" },
  "space-7": { "$type": "dimension", "$value": "2.5rem" },
  "space-8": { "$type": "dimension", "$value": "3rem" },
  "space-9": { "$type": "dimension", "$value": "4rem" }
}

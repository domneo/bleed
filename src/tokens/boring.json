{
  "$description": "WIP",

  "ink": { "$type": "color", "$value": "oklch(0.55 0.13 255)" },
  "paper": { "$type": "color", "$value": "oklch(0.99 0.004 250)" },

  "accent": { "$type": "color", "$value": "oklch(0.5 0.08 255)" },

  "positive": { "$type": "color", "$value": "oklch(0.62 0.17 150)" },
  "negative": { "$type": "color", "$value": "oklch(0.58 0.21 25)" },
  "warning": { "$type": "color", "$value": "oklch(0.75 0.16 75)" },
  "neutral": { "$type": "color", "$value": "oklch(0.62 0.02 255)" },

  "border-w": { "$type": "dimension", "$value": "1px" },
  "border-style": { "$type": "other", "$value": "solid" },

  "shadow": { "$type": "other", "$value": "0 4px 12px oklch(0.5 0.05 255 / 0.18)" },
  "shadow-hover": { "$type": "other", "$value": "0 10px 24px oklch(0.5 0.05 255 / 0.22)" },
  "shadow-active": { "$type": "other", "$value": "0 2px 6px oklch(0.5 0.05 255 / 0.16)" },

  "hover-shift-x": { "$type": "dimension", "$value": "0px" },
  "hover-shift-y": { "$type": "dimension", "$value": "0px" },

  "radius": { "$type": "dimension", "$value": "0.75rem" },

  "transition": { "$type": "other", "$value": "220ms cubic-bezier(0.2, 0, 0, 1)" },

  "font-display": { "$type": "fontFamily", "$value": "\"Inter\", system-ui, -apple-system, sans-serif" },
  "font-body": { "$type": "fontFamily", "$value": "\"Inter\", system-ui, -apple-system, sans-serif" },

  "font-size-1": { "$type": "dimension", "$value": "clamp(0.875rem, 0.833rem + 0.208vw, 1rem)" },
  "font-size-2": { "$type": "dimension", "$value": "clamp(1rem, 0.958rem + 0.208vw, 1.125rem)" },
  "font-size-3": { "$type": "dimension", "$value": "clamp(1.125rem, 1.042rem + 0.417vw, 1.375rem)" },
  "font-size-4": { "$type": "dimension", "$value": "clamp(1.375rem, 1.25rem + 0.625vw, 1.75rem)" },
  "font-size-5": { "$type": "dimension", "$value": "clamp(1.75rem, 1.583rem + 0.833vw, 2.25rem)" },
  "font-size-6": { "$type": "dimension", "$value": "clamp(2.25rem, 2rem + 1.25vw, 3rem)" },
  "font-size-7": { "$type": "dimension", "$value": "clamp(3rem, 2.667rem + 1.667vw, 4rem)" },

  "line-height-tight": { "$type": "other", "$value": "1.15" },
  "line-height-snug": { "$type": "other", "$value": "1.3" },
  "line-height-normal": { "$type": "other", "$value": "1.6" },

  "letter-spacing-tight": { "$type": "dimension", "$value": "-0.015em" },
  "letter-spacing-normal": { "$type": "dimension", "$value": "0em" },
  "letter-spacing-wide": { "$type": "dimension", "$value": "0.01em" },
  "letter-spacing-wider": { "$type": "dimension", "$value": "0.06em" },

  "space-1": { "$type": "dimension", "$value": "0.25rem" },
  "space-2": { "$type": "dimension", "$value": "0.5rem" },
  "space-3": { "$type": "dimension", "$value": "0.75rem" },
  "space-4": { "$type": "dimension", "$value": "1rem" },
  "space-5": { "$type": "dimension", "$value": "1.5rem" },
  "space-6": { "$type": "dimension", "$value": "2rem" },
  "space-7": { "$type": "dimension", "$value": "2.5rem" },
  "space-8": { "$type": "dimension", "$value": "3rem" },
  "space-9": { "$type": "dimension", "$value": "4rem" }
}
